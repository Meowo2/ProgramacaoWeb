  "description": "Backend para gerenciamento de cidades, países e continentes",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:sync": "ts-node src/config/syncDb.ts"
  },
  "dependencies": {
