generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Continente {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?

  paises Pais[]

  @@map("continente")
}

model Pais {
  id             Int     @id @default(autoincrement())
  nome           String
  populacao      BigInt?
  idioma_oficial String?
  moeda          String?
  id_continente  Int

  continente Continente @relation(fields: [id_continente], references: [id])
  cidades    Cidade[]

  @@unique([nome, id_continente])
  @@map("pais")
}

model Cidade {
  id         Int      @id @default(autoincrement())
  nome       String
  populacao  BigInt?
  latitude   Float?
  longitude  Float?
  id_pais    Int

  pais Pais @relation(fields: [id_pais], references: [id])

  @@unique([nome, id_pais])
  @@map("cidade")
}

model Usuario {
  id       Int    @id @default(autoincrement())
  nome     String
  email    String @unique
  senha    String

  @@map("usuario")
}
